    "/api/threads/{thread_id}/reply": {
      "post": {
        "tags": [
          "Dashboard"
        ],
        "summary": "Send Manual Reply",
        "description": "Sends a manual reply to a thread: creates an outgoing email, logs an Action, and resolves the thread.",
        "operationId": "send_manual_reply_api_threads__thread_id__reply_post",
        "parameters": [
          {
            "name": "thread_id",
            "in": "path",
            "required": true,
